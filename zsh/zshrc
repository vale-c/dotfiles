setopt INTERACTIVE_COMMENTS NO_BEEP CORRECT
setopt EXTENDED_GLOB

# ─── History (optimized) ─────────────────────────────────────────────────────
HISTFILE="$HOME/.zsh_history"
HISTSIZE=100000
SAVEHIST=100000
setopt EXTENDED_HISTORY HIST_EXPIRE_DUPS_FIRST HIST_FIND_NO_DUPS
setopt HIST_IGNORE_DUPS HIST_IGNORE_SPACE HIST_VERIFY
