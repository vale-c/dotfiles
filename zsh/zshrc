# ─── Functions ───────────────────────────────────────────────────────────────
mkcd() { mkdir -p "$1" && cd "$1" }

extract() {
    [[ ! -f "$1" ]] && { echo "'$1' is not a valid file"; return 1; }
    case "$1" in
        *.tar.bz2|*.tbz2) tar xjf "$1" ;;
        *.tar.gz|*.tgz)   tar xzf "$1" ;;
        *.tar.xz)         tar xJf "$1" ;;
        *.tar.zst)        tar --zstd -xf "$1" ;;
        *.bz2)            bunzip2 "$1" ;;
        *.gz)             gunzip "$1" ;;
        *.tar)            tar xf "$1" ;;
        *.zip)            unzip "$1" ;;
        *.Z)              uncompress "$1" ;;
        *.7z)             7z x "$1" ;;
        *.rar)            unrar x "$1" ;;
        *.zst)            zstd -d "$1" ;;
        *)                echo "'$1' cannot be extracted" ;;
    esac
}

killport() {
    [[ -z "$1" ]] && { echo "Usage: killport <port>"; return 1; }
    lsof -ti :"$1" | xargs kill -9 2>/dev/null && echo "Killed process on port $1" || echo "No process on port $1"
}

serve() {
    local port="${1:-8000}"
    echo "Serving on http://localhost:$port"
    python3 -m http.server "$port"
}

today() { git log --all --author="$(git config user.name)" --since="midnight" --oneline }

# ─── Power Functions ─────────────────────────────────────────────────────────
# Interactive git branch switcher with fzf
gbr() {
    git branch --sort=-committerdate --format='%(refname:short)' |
        fzf --preview 'git log --oneline --graph --color=always {} -- | head -20' |
        xargs git checkout
}

# Interactive git log browser — pick a commit, see the diff
glog() {
    git log --oneline --graph --color=always --decorate |
        fzf --ansi --no-sort --preview 'echo {} | grep -o "[a-f0-9]\{7,\}" | head -1 | xargs git show --color=always' |
        grep -o "[a-f0-9]\{7,\}" | head -1 | tr -d '\n' | pbcopy && echo "Commit hash copied!"
}

# Fuzzy find & open file in $EDITOR
fe() {
    local file
    file=$(fd --type f --hidden --follow --exclude .git | fzf --preview 'bat --color=always --style=numbers --line-range=:300 {}')
    [[ -n "$file" ]] && ${EDITOR:-nvim} "$file"
}

# Fuzzy cd into any subdirectory
fcd() {
    local dir
    dir=$(fd --type d --hidden --follow --exclude .git | fzf --preview 'eza --tree --level=2 --icons --color=always {}')
    [[ -n "$dir" ]] && cd "$dir"
}

# Quick project jumper — zoxide + fzf combo
zz() {
    local dir
    dir=$(zoxide query -l | fzf --no-sort --preview 'eza --tree --level=2 --icons --color=always {}')
    [[ -n "$dir" ]] && cd "$dir"
}

# Show git diff stats for the week
week() {
    echo "This week's work:"
    git log --all --author="$(git config user.name)" --since="1 week ago" --format="%h %s" --no-merges
    echo ""
    echo "Stats:"
    git diff --stat "$(git log --all --author="$(git config user.name)" --since="1 week ago" --format="%H" | tail -1)"..HEAD 2>/dev/null
}

# Quick note to a scratchpad
note() {
    local file="$HOME/.notes/$(date +%Y-%m-%d).md"
    mkdir -p "$HOME/.notes"
    if [[ $# -eq 0 ]]; then
        ${EDITOR:-nvim} "$file"
    else
        echo "- $(date +%H:%M) $*" >> "$file"
        echo "Noted."
    fi
}

# Yazi — cd into directory on quit with 'y'
y() {
    local tmp
    tmp="$(mktemp -t "yazi-cwd.XXXXXX")"
    yazi "$@" --cwd-file="$tmp"
    if cwd="$(command cat -- "$tmp")" && [[ -n "$cwd" ]] && [[ "$cwd" != "$PWD" ]]; then
        builtin cd -- "$cwd"
    fi
    rm -f -- "$tmp"
}

